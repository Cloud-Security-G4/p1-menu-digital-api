# CVE-2026-25971: ImageMagick DoS via circular references in MSL files
# Status: will_not_fix by Debian (imagemagick-6-common, libmagickcore-6-*, libmagickwand-6-*)
# Mitigation: MSL coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application does not process untrusted MSL files, eliminating the attack vector.
CVE-2026-25971

# CVE-2026-33900: ImageMagick DoS via integer truncation in VIFF encoder
# Status: affected (imagemagick-6-common, libmagickcore-6-*, libmagickwand-6-*)
# Mitigation: VIFF coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application only generates PNG/SVG QR codes and processes JPEG/PNG/WebP images.
CVE-2026-33900

# CVE-2023-6879: libaom3 heap-buffer-overflow on AV1 frame size change
# Status: will_not_fix by Debian (libaom3 3.6.0-1+deb12u2)
# Mitigation: AVIF coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application never processes AV1 video content.
CVE-2023-6879

# CVE-2023-39616: libaom3 invalid read memory (AOMedia v3.0.0-v3.5.0)
# Status: will_not_fix by Debian (libaom3 3.6.0-1+deb12u2)
# Mitigation: AVIF coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application never processes AV1/AVIF content.
CVE-2023-39616

# CVE-2023-5841: OpenEXR heap overflow in Scanline Deep Data parsing
# Status: no fix available in Debian 12 (libopenexr 3.1.5-5)
# Mitigation: EXR coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application never processes EXR image files.
CVE-2023-5841

# CVE-2025-12495: OpenEXR Remote Code Execution via malicious EXR file parsing
# Status: fix_deferred in Debian 12 (libopenexr 3.1.5-5)
# Mitigation: EXR coder disabled in /etc/ImageMagick-6/policy.xml (see Dockerfile)
# The application never processes EXR image files, eliminating the attack vector.
CVE-2025-12495

# CVE-2025-7458: SQLite integer overflow
# Status: no fix available in Debian 12 (libsqlite3-0 3.40.1-2+deb12u2)
# The application uses PostgreSQL exclusively via Cloud SQL. SQLite is a transitive
# OS-level dependency not reachable through any application code path.
CVE-2025-7458

# CVE-2023-45853: zlib integer overflow and heap-based buffer overflow
# Status: will_not_fix by Debian (zlib1g 1:1.2.13.dfsg-1)
# zlib is a foundational OS library; no alternative available in this base image.
# The vulnerability requires processing untrusted compressed data at the zlib level,
# which does not occur through any application-controlled code path.
CVE-2023-45853

# CVE-2026-29111: systemd arbitrary code execution or DoS via spurious IPC
# Status: no fix available in Debian 12 (libsystemd0 252.39-1~deb12u1)
# libsystemd0 is a core OS dependency; cannot be removed from the base image.
# The application is a stateless HTTP API; no privileged IPC paths are exposed.
CVE-2026-29111
